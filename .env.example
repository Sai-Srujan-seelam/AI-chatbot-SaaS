# Database
DATABASE_URL=postgresql+asyncpg://wonder:localdev123@localhost:5433/wonderchat
DATABASE_URL_SYNC=postgresql://wonder:localdev123@localhost:5433/wonderchat

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Embeddings (choose one)
VOYAGE_API_KEY=your-voyage-key-here
# OPENAI_API_KEY=your-openai-key-here

# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
# ^^^ This is also your admin API token. Pass as: Authorization: Bearer <APP_SECRET_KEY>
WIDGET_CDN_URL=http://localhost:8000/static

# CORS (comma-separated origins, * for dev)
ALLOWED_ORIGINS=*

# SMTP (optional -- for lead confirmation and notification emails)
# If not set, leads are still captured but no emails are sent.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=your-email@gmail.com
# SMTP_USE_TLS=true
